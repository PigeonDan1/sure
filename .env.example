# SURE-EVAL Environment Variables

# DashScope API Key (Alibaba Cloud Bailian)
DASHSCOPE_API_KEY=sk-f8ae3fc37bdd4953977e813f77b7324f

# Hugging Face Token (for model download)
HF_TOKEN=your-huggingface-token

# ModelScope Token (optional)
MODELSCOPE_TOKEN=your-modelscope-token

# Configuration path
SURE_EVAL_CONFIG=./config/default.yaml

# Data directories (optional, defaults to ./data)
SURE_EVAL_DATA_DIR=./data
SURE_EVAL_RESULTS_DIR=./results

# API endpoints (for external tool APIs)
TOOL_API_BASE_URL=http://localhost:8000
TOOL_API_KEY=your-tool-api-key

MODEL_API_BASE_URL=http://localhost:8080
MODEL_API_KEY=your-model-api-key

# Logging
LOG_LEVEL=INFO
